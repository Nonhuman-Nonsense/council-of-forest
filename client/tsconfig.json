{
    "compilerOptions": {
        "target": "ES2021",
        "useDefineForClassFields": true,
        "lib": [
            "ES2021",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "paths": {
            "@/logger": [
                "./src/logger.prod.ts"
            ],
            "@/*": [
                "./src/*"
            ],
            "@api/*": [
                "./src/api/*"
            ],
            "@assets/*": [
                "./src/assets/*"
            ],
            "@council/*": [
                "./src/council/*"
            ],
            "@forest/*": [
                "./src/forest/*"
            ],
            "@locales/*": [
                "./src/locales/*"
            ],
            "@main/*": [
                "./src/main/*"
            ],
            "@newMeeting/*": [
                "./src/newMeeting/*"
            ],
            "@voice/*": [
                "./src/voice/*"
            ],
            "@realtime/*": [
                "./src/realtime/*"
            ],
            "@museum/*": [
                "./src/museum/*"
            ],
            "@shared/*": [
                "../shared/*"
            ]
        },
        "allowJs": true,
        "strict": false,
        "checkJs": false,
        "maxNodeModuleJsDepth": 0
    },
    "include": [
        "src",
        "tests",
        "../shared"
    ]
}